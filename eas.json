{
  "cli": {
    "version": ">= 16.15.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "ANDROID_PLAY_SIGNING_SHA256": "3A:E9:0E:D7:CB:AD:E4:22:DF:26:EC:23:C9:99:B6:EC:22:C3:47:F8:65:5F:5E:53:1E:70:B3:17:97:0C:12:F7"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6784162235",
        "appleId": "greenlandscapecompany@gmail.com",
        "appleTeamId": "JRY2D7Y76N"
      }
    }
  }
}
