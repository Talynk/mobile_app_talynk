{
  "expo": {
    "owner": "smartappslink",
    "name": "Talentix",
    "slug": "talentix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-square.png",
    "scheme": "talentix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "linking": {
      "prefixes": [
        "https://talentix.godetour.link",
        "talentix://"
      ]
    },
    "splash": {
      "image": "./assets/images/mobile-app-logo-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ihirwe.talentix",
      "associatedDomains": [
        "applinks:talentix.godetour.link"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Talentix to access your camera to record videos and take photos.",
        "NSMicrophoneUsageDescription": "Allow Talentix to access your microphone to record audio with your videos.",
        "NSPhotoLibraryUsageDescription": "Allow Talentix to access your photos and videos so you can upload content.",
        "NSPhotoLibraryAddUsageDescription": "Allow Talentix to save photos and videos to your library.",
        "NSLocationWhenInUseUsageDescription": "Talentix uses your approximate location to suggest your country during registration and improve regional content recommendations. Location is not tracked in the background.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "applinks:talentix.godetour.link"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ihirwe.talentix",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "talentix.godetour.link",
              "pathPrefix": "/mIlEGaC9ru"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Talentix to access your camera to record videos and take photos.",
          "microphonePermission": "Allow Talentix to access your microphone to record audio with your videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "2.0.21",
            "packagingOptions": {
              "pickFirst": [
                "lib/x86/libc++_shared.so",
                "lib/x86_64/libc++_shared.so",
                "lib/armeabi-v7a/libc++_shared.so",
                "lib/arm64-v8a/libc++_shared.so"
              ]
            }
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Talentix to save photos and videos to your library.",
          "savePhotosPermission": "Allow Talentix to save photos and videos to your library.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "strongminds",
          "project": "talentix"
        }
      ],
      "react-native-compressor",
      "react-native-vision-camera",
      "./plugins/withUserLeaveHintGuard",
      "./plugins/withAndroidDetourAppLinks",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eba91790-fe7a-4c3d-a3e4-f939266e69d3"
      }
    }
  }
}
